# Google Gemini API (server-only — never expose to the browser)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=replace_with_current_gemini_model_id

# Local server
PORT=8787

# CORS: Vite dev origin
WEB_ORIGIN=http://localhost:5173

# Optional: set to "mock" for offline deterministic analysis (no Gemini calls).
# Default is live Gemini. Missing credentials fail closed with HTTP 503.
# ANALYZE_MODE=mock
